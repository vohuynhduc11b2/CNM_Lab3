<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Product</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Georgia', 'Times New Roman', serif;
            background: #f5f1e8;
            background-image: 
                repeating-linear-gradient(0deg, transparent, transparent 35px, rgba(139, 69, 19, 0.03) 35px, rgba(139, 69, 19, 0.03) 36px),
                repeating-linear-gradient(90deg, transparent, transparent 35px, rgba(139, 69, 19, 0.03) 35px, rgba(139, 69, 19, 0.03) 36px);
            min-height: 100vh;
            padding: 40px 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #3e2723;
        }

        .container {
            max-width: 600px;
            width: 100%;
        }

        .form-card {
            background: #fff;
            border: none;
            border-radius: 20px;
            padding: 40px;
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1), 0 4px 8px rgba(0, 0, 0, 0.06), inset 0 0 0 2px #8d6e63;
        }

        h1 {
            color: #4e342e;
            font-size: 2rem;
            margin-bottom: 30px;
            text-align: center;
            font-weight: normal;
            letter-spacing: 2px;
            text-transform: uppercase;
            border-bottom: 3px double #8d6e63;
            padding-bottom: 15px;
        }

        .form-group {
            margin-bottom: 25px;
        }

        label {
            display: block;
            color: #4e342e;
            font-weight: bold;
            margin-bottom: 8px;
            font-size: 1rem;
        }

        input[type="text"],
        input[type="number"] {
            width: 100%;
            padding: 12px 16px;
            background: #fafafa;
            border: 2px solid #d7ccc8;
            border-radius: 10px;
            font-size: 1rem;
            transition: all 0.3s ease;
            font-family: 'Georgia', serif;
            color: #3e2723;
        }

        input[type="text"]::placeholder,
        input[type="number"]::placeholder {
            color: #bcaaa4;
        }

        input[type="text"]:focus,
        input[type="number"]:focus {
            outline: none;
            border-color: #8d6e63;
            background: #fff;
            box-shadow: 0 0 0 4px rgba(141, 110, 99, 0.1), 0 2px 8px rgba(0, 0, 0, 0.08);
            transform: translateY(-1px);
        }

        input[type="file"] {
            width: 100%;
            padding: 16px;
            background: linear-gradient(135deg, #fafafa 0%, #fff 100%);
            border: 2px dashed #8d6e63;
            border-radius: 10px;
            cursor: pointer;
            transition: all 0.3s ease;
            color: #5d4037;
            font-family: 'Georgia', serif;
        }

        input[type="file"]:hover {
            border-color: #6d4c41;
            background: #fff;
            box-shadow: 0 4px 12px rgba(141, 110, 99, 0.15);
            transform: translateY(-2px);
        }

        .btn-group {
            display: flex;
            gap: 15px;
            margin-top: 30px;
        }

        button,
        .btn-back {
            flex: 1;
            padding: 16px;
            border: none;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            text-align: center;
            font-family: 'Georgia', serif;
            letter-spacing: 1px;
            border-radius: 12px;
            position: relative;
            overflow: hidden;
        }

        button::before,
        .btn-back::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 50%;
            width: 0;
            height: 0;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.2);
            transform: translate(-50%, -50%);
            transition: width 0.5s, height 0.5s;
        }

        button:hover::before,
        .btn-back:hover::before {
            width: 300px;
            height: 300px;
        }

        button {
            background: #8d6e63;
            color: white;
            box-shadow: 0 4px 12px rgba(141, 110, 99, 0.4);
        }

        button:hover {
            background: #6d4c41;
            transform: translateY(-2px);
            box-shadow: 0 6px 16px rgba(141, 110, 99, 0.5);
        }

        button:active {
            transform: translateY(0);
            box-shadow: 0 2px 8px rgba(141, 110, 99, 0.3);
        }

        .btn-back {
            background: #efebe9;
            color: #5d4037;
            box-shadow: 0 4px 12px rgba(188, 170, 164, 0.3);
        }

        .btn-back:hover {
            background: #d7ccc8;
            transform: translateY(-2px);
            box-shadow: 0 6px 16px rgba(188, 170, 164, 0.4);
        }

        .file-info {
            font-size: 0.85rem;
            color: #8d6e63;
            margin-top: 6px;
            font-style: italic;
        }

        @media (max-width: 768px) {
            .form-card {
                padding: 35px 25px;
            }

            h1 {
                font-size: 1.8rem;
            }

            .btn-group {
                flex-direction: column;
            }
        }
    </style>
</head>
<body>

<div class="container">
    <div class="form-card">
        <h1>➕ Add New Product</h1>

        <form action="/add" method="POST" enctype="multipart/form-data">
            <div class="form-group">
                <label>Product Name:</label>
                <input type="text" name="name" placeholder="Enter product name" required>
            </div>

            <div class="form-group">
                <label>Price ($):</label>
                <input type="number" name="price" step="0.01" placeholder="0.00" required>
            </div>

            <div class="form-group">
                <label>Quantity:</label>
                <input type="number" name="quantity" placeholder="0" required>
            </div>

            <div class="form-group">
                <label>Product Image:</label>
                <input type="file" name="image" accept="image/*">
                <div class="file-info">📸 Upload an image (optional)</div>
            </div>

            <div class="btn-group">
                <button type="submit">✓ Add Product</button>
                <a href="/" class="btn-back">← Back to List</a>
            </div>
        </form>
    </div>
</div>

</body>
</html>
