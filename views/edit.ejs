<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Product</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Georgia', 'Times New Roman', serif;
            background: #f5f1e8;
            background-image: 
                repeating-linear-gradient(0deg, transparent, transparent 35px, rgba(139, 69, 19, 0.03) 35px, rgba(139, 69, 19, 0.03) 36px),
                repeating-linear-gradient(90deg, transparent, transparent 35px, rgba(139, 69, 19, 0.03) 35px, rgba(139, 69, 19, 0.03) 36px);
            min-height: 100vh;
            padding: 40px 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #3e2723;
        }

        .container {
            max-width: 600px;
            width: 100%;
        }

        .form-card {
            background: #fff;
            border: 3px solid #8d6e63;
            padding: 40px;
            box-shadow: 8px 8px 0 #d7ccc8;
        }

        h1 {
            color: #4e342e;
            font-size: 2rem;
            margin-bottom: 30px;
            text-align: center;
            font-weight: normal;
            letter-spacing: 2px;
            text-transform: uppercase;
            border-bottom: 3px double #8d6e63;
            padding-bottom: 15px;
        }

        .form-group {
            margin-bottom: 25px;
        }

        label {
            display: block;
            color: #4e342e;
            font-weight: bold;
            margin-bottom: 8px;
            font-size: 1rem;
        }

        input[type="text"],
        input[type="number"] {
            width: 100%;
            padding: 12px;
            background: #fafafa;
            border: 2px solid #8d6e63;
            font-size: 1rem;
            transition: all 0.2s ease;
            font-family: 'Georgia', serif;
            color: #3e2723;
        }

        input[type="text"]::placeholder,
        input[type="number"]::placeholder {
            color: #bcaaa4;
        }

        input[type="text"]:focus,
        input[type="number"]:focus {
            outline: none;
            border-color: #6d4c41;
            background: #fff;
            box-shadow: 3px 3px 0 #d7ccc8;
        }

        .current-image {
            width: 200px;
            height: 200px;
            object-fit: cover;
            margin-bottom: 15px;
            border: 3px solid #8d6e63;
            filter: sepia(20%);
        }

        .no-image {
            width: 200px;
            height: 200px;
            background: #efebe9;
            border: 3px dashed #8d6e63;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #8d6e63;
            font-size: 1rem;
            margin-bottom: 15px;
            font-style: italic;
        }

        input[type="file"] {
            width: 100%;
            padding: 12px;
            background: #fafafa;
            border: 2px dashed #8d6e63;
            cursor: pointer;
            transition: all 0.2s ease;
            color: #5d4037;
            font-family: 'Georgia', serif;
        }

        input[type="file"]:hover {
            border-color: #6d4c41;
            background: #fff;
        }

        .btn-group {
            display: flex;
            gap: 15px;
            margin-top: 30px;
        }

        button,
        .btn-back {
            flex: 1;
            padding: 14px;
            border: 2px solid;
            font-size: 1rem;
            font-weight: normal;
            cursor: pointer;
            transition: all 0.2s ease;
            text-decoration: none;
            display: inline-block;
            text-align: center;
            font-family: 'Georgia', serif;
            letter-spacing: 1px;
        }

        button {
            background: #8d6e63;
            color: white;
            border-color: #6d4c41;
            box-shadow: 0 3px 0 #6d4c41;
        }

        button:hover {
            background: #6d4c41;
            transform: translateY(2px);
            box-shadow: 0 1px 0 #6d4c41;
        }

        button:active {
            transform: translateY(3px);
            box-shadow: none;
        }

        .btn-back {
            background: #efebe9;
            color: #5d4037;
            border-color: #8d6e63;
            box-shadow: 0 3px 0 #bcaaa4;
        }

        .btn-back:hover {
            background: #d7ccc8;
            transform: translateY(2px);
            box-shadow: 0 1px 0 #bcaaa4;
        }

        .file-info {
            font-size: 0.85rem;
            color: #8d6e63;
            margin-top: 6px;
            font-style: italic;
        }

        .image-preview {
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 20px;
            background: #fafafa;
            border: 2px solid #d7ccc8;
            margin-bottom: 15px;
        }

        @media (max-width: 768px) {
            .form-card {
                padding: 30px 20px;
            }

            h1 {
                font-size: 1.6rem;
            }

            .btn-group {
                flex-direction: column;
            }

            .current-image,
            .no-image {
                width: 160px;
                height: 160px;
            }
        }
    </style>
        }

        button,
        .btn-back {
            flex: 1;
            padding: 14px;
            border: none;
            border-radius: 10px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            text-decoration: none;
            display: inline-block;
            text-align: center;
        }

        button {
            background: #8d6e63;
            color: white;
            border-color: #6d4c41;
            box-shadow: 0 3px 0 #6d4c41;
        }

        button:hover {
            background: #6d4c41;
            transform: translateY(2px);
            box-shadow: 0 1px 0 #6d4c41;
        }

        button:active {
            transform: translateY(3px);
            box-shadow: none;
        }

        .btn-back {
            background: #efebe9;
            color: #5d4037;
            border-color: #8d6e63;
            box-shadow: 0 3px 0 #bcaaa4;
        }

        .btn-back:hover {
            background: #d7ccc8;
            transform: translateY(2px);
            box-shadow: 0 1px 0 #bcaaa4;
        }

        .file-info {
            font-size: 0.85rem;
            color: #8d6e63;
            margin-top: 6px;
            font-style: italic;
        }

        .image-preview {
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 20px;
            background: #fafafa;
            border: 2px solid #d7ccc8;
            margin-bottom: 15px;
        }

        @media (max-width: 768px) {
            .form-card {
                padding: 30px 20px;
            }

            h1 {
                font-size: 1.6rem;
            }

            .btn-group {
                flex-direction: column;
            }

            .current-image,
            .no-image {
                width: 150px;
                height: 150px;
            }
        }
    </style>
</head>
<body>

<div class="container">
    <div class="form-card">
        <h1>Edit Product</h1>

        <form action="/edit/<%= product.id %>" method="POST" enctype="multipart/form-data">
            <div class="form-group">
                <label>Product Name:</label>
                <input type="text" name="name" value="<%= product.name %>" placeholder="Enter product name" required>
            </div>

            <div class="form-group">
                <label>Price ($):</label>
                <input type="number" name="price" value="<%= product.price %>" step="0.01" placeholder="0.00" required>
            </div>

            <div class="form-group">
                <label>Quantity:</label>
                <input type="number" name="quantity" value="<%= product.quantity %>" placeholder="0" required>
            </div>

            <div class="form-group">
                <label>Current Image:</label>
                <div class="image-preview">
                    <% if (product.url_image) { %>
                        <img src="<%= product.url_image %>" class="current-image" alt="Current product image">
                    <% } else { %>
                        <div class="no-image">No Image</div>
                    <% } %>
                </div>
            </div>

            <div class="form-group">
                <label>Update Image:</label>
                <input type="file" name="image" accept="image/*">
                <div class="file-info">Optional: Upload a new image</div>
            </div>

            <div class="btn-group">
                <button type="submit">Save Changes</button>
                <a href="/" class="btn-back">← Back</a>
            </div>
        </form>
    </div>
</div>

</body>
</html>
